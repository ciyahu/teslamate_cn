          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    date_trunc('minute', timezone('UTC', date), '$__timezone') AS time,\n    avg(gcj_lat) AS latitude,\n    avg(gcj_lon) AS longitude\nFROM\n    positions\nWHERE\n    car_id::text = ANY(string_to_array('${car_id:csv}', ','))\n    AND $__timeFilter(date)\n    AND ideal_battery_range_km IS NOT NULL\n    AND gcj_lat IS NOT NULL\n    AND gcj_lon IS NOT NULL\nGROUP BY 1\nORDER BY 1",
          "refId": "Positions",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
